# frontend/app — copy to .env.local for production, .env.development.local for local dev

# Django REST API base URL
# Production:  https://api.tradalyst.com
# Local dev:   http://localhost:8000
NEXT_PUBLIC_API_URL=

# Marketing site URL — used for logo link and pricing page CTA
# Production:  https://tradalyst.com
# Local dev:   http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=
