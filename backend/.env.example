# Copy this file to .env and fill in the values.
# Never commit .env to version control.

DJANGO_SETTINGS_MODULE=tradalyst.settings.development

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Local: postgresql://postgres:password@localhost:5432/tradalyst_dev
DATABASE_URL=

# Get from console.anthropic.com
CLAUDE_API_KEY=

# Get from finnhub.io
FINNHUB_API_KEY=

# Get from dashboard.stripe.com/apikeys (use sk_test_... for test mode)
STRIPE_SECRET_KEY=
# Get from dashboard.stripe.com/webhooks after creating the webhook endpoint
STRIPE_WEBHOOK_SECRET=
# The price ID for the PRO monthly plan (price_...)
STRIPE_PRO_PRICE_ID=

# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SIGNING_KEY=

# Production only — comma-separated list of hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Production only — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
